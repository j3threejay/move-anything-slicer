{
  "title": "Sample Slicer",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Transient-detection",
        "sample slicer.",
        "",
        "Load a WAV file,",
        "detect transients,",
        "play slices via",
        "pads or keyboard."
      ]
    },
    {
      "title": "Quick Start",
      "lines": [
        "1. Browse & select",
        "   a WAV sample",
        "2. Adjust threshold",
        "   with jog wheel",
        "3. Click jog to scan",
        "4. Hit pads to play",
        "   slices"
      ]
    },
    {
      "title": "Controls",
      "children": [
        {
          "title": "Knobs 1-4 (Bank A)",
          "lines": [
            "Per-Pad [P] default:",
            " K1: Attack",
            " K2: Decay",
            " K3: Start trim",
            " K4: End trim",
            "",
            "Global [G] mode:",
            " K1: Attack (all)",
            " K2: Decay (all)",
            " K3-K4: inactive",
            "",
            "Jog click toggles",
            "[P] / [G] scope."
          ]
        },
        {
          "title": "Knobs 5-8 (Bank B)",
          "lines": [
            "Per-Pad [P] default:",
            " K5: Mode (gate/trig)",
            " K6: Pitch offset",
            " K7: Pad gain (mult)",
            " K8: Loop mode",
            "",
            "Global [G] mode:",
            " K5: Mode (gate/trig)",
            " K6: Pitch (+/-24st)",
            " K7: Gain (global)",
            " K8: Loop mode",
            "",
            "Jog click toggles",
            "[P] / [G] scope."
          ]
        },
        {
          "title": "Jog Wheel",
          "lines": [
            "Browser: scroll list",
            "Main: adjust thresh",
            "Click: scan/select",
            "",
            "Ready: click toggles",
            " Per-Pad / Global",
            " edit scope."
          ]
        },
        {
          "title": "Knob Touch",
          "lines": [
            "Touch knobs 1-4 to",
            "show Bank A display.",
            "Touch knobs 5-8 to",
            "show Bank B display.",
            "",
            "Display persists",
            "across pad presses."
          ]
        }
      ]
    },
    {
      "title": "MIDI Mapping",
      "lines": [
        "Pads (68-99):",
        " Slices 0-31 direct",
        "",
        "Keyboard (C2 root):",
        " Note 36+ chromatic",
        " Up to 91 slices"
      ]
    },
    {
      "title": "Modes",
      "lines": [
        "Gate: plays while",
        " pad held, decay",
        " on release",
        "",
        "Trigger: plays full",
        " slice regardless",
        " of pad hold time",
        "",
        "Loop: forward or",
        " ping-pong looping",
        " within slice bounds"
      ]
    }
  ]
}
