{
  "title": "Sample Slicer",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Transient-detection",
        "sample slicer.",
        "",
        "Load a WAV file,",
        "detect transients,",
        "play slices via",
        "pads or keyboard."
      ]
    },
    {
      "title": "Quick Start",
      "lines": [
        "1. Browse & select",
        "   a WAV sample",
        "2. Adjust threshold",
        "   with jog wheel",
        "3. Click jog to scan",
        "4. Hit pads to play",
        "   slices"
      ]
    },
    {
      "title": "Controls",
      "children": [
        {
          "title": "Knobs 1-4 (Bank A)",
          "lines": [
            "Knob 1: Start trim",
            "Knob 2: End trim",
            "Knob 3: Attack",
            "Knob 4: Decay",
            "",
            "Per-pad parameters",
            "for selected slice."
          ]
        },
        {
          "title": "Knobs 5-8 (Bank B)",
          "lines": [
            "Global [G] mode:",
            " K5: Mode (gate/trig)",
            " K6: Pitch (+/-24st)",
            " K7: Gain (global)",
            " K8: Loop mode",
            "",
            "Per-Pad [P] mode:",
            " K5: Pad mode override",
            " K6: Pad pitch offset",
            " K7: Pad gain (mult)",
            " K8: Loop mode",
            "",
            "Jog click in Bank B",
            "toggles [G] / [P]."
          ]
        },
        {
          "title": "Jog Wheel",
          "lines": [
            "Browser: scroll list",
            "Main: adjust thresh",
            "Click: scan/select",
            "",
            "Bank A: click opens",
            " sensitivity screen.",
            "Bank B: click toggles",
            " Global/Per-Pad edit."
          ]
        },
        {
          "title": "Knob Touch",
          "lines": [
            "Touch knobs 1-4 to",
            "show Bank A display.",
            "Touch knobs 5-8 to",
            "show Bank B display.",
            "",
            "Display persists",
            "across pad presses."
          ]
        }
      ]
    },
    {
      "title": "MIDI Mapping",
      "lines": [
        "Pads (68-99):",
        " Slices 0-31 direct",
        "",
        "Keyboard (C2 root):",
        " Note 36+ chromatic",
        " Up to 91 slices",
        "",
        "Velocity sensitive",
        "when enabled."
      ]
    },
    {
      "title": "Modes",
      "lines": [
        "Gate: plays while",
        " pad held, decay",
        " on release",
        "",
        "Trigger: plays full",
        " slice regardless",
        " of pad hold time",
        "",
        "Loop: forward or",
        " ping-pong looping",
        " within slice bounds"
      ]
    }
  ]
}
